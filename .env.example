# ===========================================
# SWALO - Configuration Environnement
# ===========================================

# -----------------------------------------
# BASE DE DONNÉES (Neon - PostgreSQL Serverless)
# -----------------------------------------
# Dev local: utiliser PostgreSQL dans Docker
# Production: utiliser Neon (https://console.neon.tech)
#
# Format Neon:
# postgresql://user:password@ep-xxx.region.aws.neon.tech/swalo_db?sslmode=require
#
# Avec connection pooling (recommandé):
# postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/swalo_db?sslmode=require
DATABASE_URL=postgresql://swalo:swalo_password@localhost:5432/swalo_db?schema=public

# -----------------------------------------
# JWT AUTHENTICATION
# -----------------------------------------
# Générer avec: openssl rand -base64 32
JWT_SECRET=change_this_secret_in_production
JWT_REFRESH_SECRET=change_this_refresh_secret_in_production
JWT_EXPIRES_IN=7d

# -----------------------------------------
# API CONFIGURATION
# -----------------------------------------
NODE_ENV=development
PORT=3000

# -----------------------------------------
# FRONTEND (Web)
# -----------------------------------------
# Dev: http://localhost:3000/api
# Prod: https://swalo-api.onrender.com/api
VITE_API_URL=http://localhost:3000/api

# -----------------------------------------
# FRONTEND (Mobile)
# -----------------------------------------
# Dev local (réseau): http://192.168.x.x:3000/api
# Prod: https://swalo-api.onrender.com/api
EXPO_PUBLIC_API_URL=http://localhost:3000/api

# -----------------------------------------
# DATABASE SEEDING
# -----------------------------------------
# Activer le seed automatique au démarrage (dev uniquement)
RUN_DB_SEED=false

# -----------------------------------------
# DOCKER (Dev local uniquement)
# -----------------------------------------
POSTGRES_USER=swalo
POSTGRES_PASSWORD=swalo_password
POSTGRES_DB=swalo_db
