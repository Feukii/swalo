# Development Configuration (Neon Database - Branch dev)
# Copiez ce fichier en .env.development et remplissez avec vos vraies valeurs

# PostgreSQL Configuration (Neon)
POSTGRES_USER=neondb_owner
POSTGRES_PASSWORD=your_neon_password
POSTGRES_DB=neondb

# API Configuration
NODE_ENV=development
PORT=3000
JWT_SECRET=dev_jwt_secret_key_not_for_production
JWT_REFRESH_SECRET=dev_jwt_refresh_secret_key_not_for_production
JWT_EXPIRES_IN=7d

# Database URL (Neon Cloud Database - Development Branch)
# Créez une branche 'dev' sur Neon et copiez l'URL ici
DATABASE_URL=postgresql://neondb_owner:password@ep-xxx-xxx.region.aws.neon.tech/neondb?sslmode=require

# Frontend Configuration
VITE_API_URL=http://localhost:3000/api
