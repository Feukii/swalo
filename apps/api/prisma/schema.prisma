generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Shop {
  id                  String              @id @default(uuid())
  code                String              @unique @db.VarChar(10)
  name                String              @db.VarChar(255)
  address             String?
  phone               String?
  email               String?
  currency            String              @default("XOF") @db.VarChar(3)
  tax_rate            Float               @default(0)
  owner_id            String
  created_at          DateTime            @default(now())
  updated_at          DateTime            @updatedAt
  deleted             Boolean             @default(false)
  deleted_at          DateTime?
  version             Int                 @default(1)
  cash_entries        CashEntry[]
  cash_sessions       CashSession[]
  client_receivables  ClientReceivable[]
  customers           Customer[]
  device_sync_states  DeviceSyncState[]
  inventory_movements InventoryMovement[]
  inventory_sessions  InventorySession[]
  invoices            Invoice[]
  payments            Payment[]
  products            Product[]
  sales               Sale[]
  owner               User                @relation(fields: [owner_id], references: [id])
  stock_batches       StockBatch[]
  supplier_debts      SupplierDebt[]
  supplier_invoices   SupplierInvoice[]
  suppliers           Supplier[]
  user_roles          UserRole[]
  packaging_types     PackagingType[]

  @@map("shops")
}

model User {
  id                 String             @id @default(uuid())
  email              String?            @unique
  phone              String?            @unique
  password_hash      String?
  display_name       String             @db.VarChar(255)
  is_active          Boolean            @default(true)
  created_at         DateTime           @default(now())
  updated_at         DateTime           @updatedAt
  deleted            Boolean            @default(false)
  deleted_at         DateTime?
  version            Int                @default(1)
  pin_code           String?            @db.VarChar(4)
  cash_entries       CashEntry[]
  cash_sessions      CashSession[]
  inventory_sessions InventorySession[]
  sales              Sale[]
  shops_owned        Shop[]
  user_roles         UserRole[]

  @@map("users")
}

model UserRole {
  id              String    @id @default(uuid())
  user_id         String
  shop_id         String
  role            Role
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt
  deleted         Boolean   @default(false)
  deleted_at      DateTime?
  version         Int       @default(1)
  work_days       String?
  work_end_time   String?   @db.VarChar(5)
  work_start_time String?   @db.VarChar(5)
  shop            Shop      @relation(fields: [shop_id], references: [id])
  user            User      @relation(fields: [user_id], references: [id])

  @@unique([user_id, shop_id])
  @@map("user_roles")
}

model UserDevice {
  id            String    @id @default(uuid())
  user_id       String
  shop_id       String
  device_id     String    @db.VarChar(255)
  device_name   String?   @db.VarChar(255)
  device_type   String?   @db.VarChar(50)
  last_login_at DateTime?
  is_active     Boolean   @default(true)
  revoked_at    DateTime?
  revoked_by    String?
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  @@unique([user_id, shop_id, device_id])
  @@index([user_id, shop_id])
  @@map("user_devices")
}

model Product {
  id                     String                @id @default(uuid())
  shop_id                String
  sku                    String                @db.VarChar(50)
  barcode                String?
  name                   String                @db.VarChar(255)
  description            String?
  category               String?
  family                 String?               @db.VarChar(100)
  article_type           String?               @db.VarChar(100)
  brand                  String?               @db.VarChar(100)
  reference              String?               @db.VarChar(100)
  unit                   String                @default("unit") @db.VarChar(20)
  packaging_type_id      String?
  tax_rate               Float                 @default(0)
  cost_price             Int
  sell_price             Int
  is_active              Boolean               @default(true)
  alert_threshold        Int                   @default(5)
  image_url              String?
  created_at             DateTime              @default(now())
  updated_at             DateTime              @updatedAt
  deleted                Boolean               @default(false)
  deleted_at             DateTime?
  version                Int                   @default(1)
  device_id              String?
  client_op_id           String?
  inventory_counts       InventoryCount[]
  inventory_movements    InventoryMovement[]
  invoice_items          InvoiceItem[]
  packaging_type         PackagingType?        @relation(fields: [packaging_type_id], references: [id])
  shop                   Shop                  @relation(fields: [shop_id], references: [id])
  sale_items             SaleItem[]
  supplier_invoice_items SupplierInvoiceItem[]
  stock_batches          StockBatch[]

  @@unique([shop_id, sku])
  @@index([shop_id, is_active])
  @@index([shop_id, category])
  @@map("products")
}

model StockBatch {
  id                 String    @id @default(uuid())
  shop_id            String
  product_id         String
  quantity           Int
  remaining_quantity Int
  cost_price         Int
  sell_price         Int
  price_valid_from   DateTime  @default(now())
  price_valid_until  DateTime?
  notes              String?
  deleted            Boolean   @default(false)
  deleted_at         DateTime?
  created_at         DateTime  @default(now())
  updated_at         DateTime  @updatedAt
  product            Product   @relation(fields: [product_id], references: [id])
  shop               Shop      @relation(fields: [shop_id], references: [id])

  @@index([shop_id, product_id])
  @@index([remaining_quantity])
  @@index([price_valid_from])
  @@map("stock_batches")
}

model PackagingType {
  id         String    @id @default(uuid())
  shop_id    String
  name       String    @db.VarChar(50)
  symbol     String?   @db.VarChar(10)
  is_default Boolean   @default(false)
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  deleted    Boolean   @default(false)
  deleted_at DateTime?
  products   Product[]
  shop       Shop      @relation(fields: [shop_id], references: [id])

  @@unique([shop_id, name])
  @@map("packaging_types")
}

model InventoryMovement {
  id           String       @id @default(uuid())
  shop_id      String
  product_id   String
  type         MovementType
  qty          Int
  reason       String?
  ref_type     String?
  ref_id       String?
  unit_cost    Int?
  device_id    String
  client_op_id String       @unique
  created_at   DateTime     @default(now())
  updated_at   DateTime     @updatedAt
  deleted      Boolean      @default(false)
  deleted_at   DateTime?
  version      Int          @default(1)
  product      Product      @relation(fields: [product_id], references: [id])
  shop         Shop         @relation(fields: [shop_id], references: [id])

  @@index([shop_id, product_id, created_at])
  @@index([device_id, client_op_id])
  @@map("inventory_movements")
}

model InventorySession {
  id           String           @id @default(uuid())
  shop_id      String
  user_id      String
  status       SessionStatus
  started_at   DateTime
  completed_at DateTime?
  notes        String?
  created_at   DateTime         @default(now())
  updated_at   DateTime         @updatedAt
  deleted      Boolean          @default(false)
  deleted_at   DateTime?
  version      Int              @default(1)
  counts       InventoryCount[]
  shop         Shop             @relation(fields: [shop_id], references: [id])
  user         User             @relation(fields: [user_id], references: [id])

  @@map("inventory_sessions")
}

model InventoryCount {
  id           String           @id @default(uuid())
  session_id   String
  product_id   String
  expected_qty Int
  counted_qty  Int
  difference   Int
  notes        String?
  created_at   DateTime         @default(now())
  updated_at   DateTime         @updatedAt
  deleted      Boolean          @default(false)
  deleted_at   DateTime?
  version      Int              @default(1)
  product      Product          @relation(fields: [product_id], references: [id])
  session      InventorySession @relation(fields: [session_id], references: [id])

  @@map("inventory_counts")
}

model Customer {
  id           String             @id @default(uuid())
  shop_id      String
  code         String?
  name         String             @db.VarChar(255)
  phone        String?
  email        String?
  address      String?
  credit_limit Int                @default(0)
  notes        String?
  is_active    Boolean            @default(true)
  created_at   DateTime           @default(now())
  updated_at   DateTime           @updatedAt
  deleted      Boolean            @default(false)
  deleted_at   DateTime?
  version      Int                @default(1)
  first_name   String?            @db.VarChar(255)
  cash_entries CashEntry[]
  receivables  ClientReceivable[]
  shop         Shop               @relation(fields: [shop_id], references: [id])
  invoices     Invoice[]
  sales        Sale[]

  @@index([shop_id, is_active])
  @@map("customers")
}

model ClientReceivable {
  id          String                    @id @default(uuid())
  shop_id     String
  customer_id String
  amount      Int
  paid_amount Int                       @default(0)
  balance     Int
  description String?
  notes       String?
  status      ReceivableStatus          @default(PENDING)
  created_at  DateTime                  @default(now())
  updated_at  DateTime                  @updatedAt
  deleted     Boolean                   @default(false)
  deleted_at  DateTime?
  version     Int                       @default(1)
  payments    ClientReceivablePayment[]
  customer    Customer                  @relation(fields: [customer_id], references: [id])
  shop        Shop                      @relation(fields: [shop_id], references: [id])

  @@index([shop_id, customer_id])
  @@index([shop_id, status])
  @@map("client_receivables")
}

model ClientReceivablePayment {
  id            String           @id @default(uuid())
  receivable_id String
  amount        Int
  payment_date  DateTime         @default(now())
  notes         String?
  cashier_id    String?
  created_at    DateTime         @default(now())
  updated_at    DateTime         @updatedAt
  deleted       Boolean          @default(false)
  deleted_at    DateTime?
  version       Int              @default(1)
  cash_entry_id String?
  receivable    ClientReceivable @relation(fields: [receivable_id], references: [id])

  @@index([receivable_id])
  @@map("client_receivable_payments")
}

model Supplier {
  id           String            @id @default(uuid())
  shop_id      String
  code         String?
  name         String            @db.VarChar(255)
  phone        String?
  email        String?
  address      String?
  notes        String?
  is_active    Boolean           @default(true)
  created_at   DateTime          @default(now())
  updated_at   DateTime          @updatedAt
  deleted      Boolean           @default(false)
  deleted_at   DateTime?
  version      Int               @default(1)
  first_name   String?           @db.VarChar(255)
  cash_entries CashEntry[]
  debts        SupplierDebt[]
  invoices     SupplierInvoice[]
  shop         Shop              @relation(fields: [shop_id], references: [id])

  @@index([shop_id, is_active])
  @@map("suppliers")
}

model SupplierDebt {
  id          String                @id @default(uuid())
  shop_id     String
  supplier_id String
  amount      Int
  paid_amount Int                   @default(0)
  balance     Int
  description String?
  notes       String?
  status      DebtStatus            @default(PENDING)
  created_at  DateTime              @default(now())
  updated_at  DateTime              @updatedAt
  deleted     Boolean               @default(false)
  deleted_at  DateTime?
  version     Int                   @default(1)
  payments    SupplierDebtPayment[]
  shop        Shop                  @relation(fields: [shop_id], references: [id])
  supplier    Supplier              @relation(fields: [supplier_id], references: [id])

  @@index([shop_id, supplier_id])
  @@index([shop_id, status])
  @@map("supplier_debts")
}

model SupplierDebtPayment {
  id           String       @id @default(uuid())
  debt_id      String
  amount       Int
  payment_date DateTime     @default(now())
  notes        String?
  cashier_id   String?
  cash_exit_id String?
  created_at   DateTime     @default(now())
  updated_at   DateTime     @updatedAt
  deleted      Boolean      @default(false)
  deleted_at   DateTime?
  version      Int          @default(1)
  debt         SupplierDebt @relation(fields: [debt_id], references: [id])

  @@index([debt_id])
  @@map("supplier_debt_payments")
}

model SupplierInvoice {
  id           String                @id @default(uuid())
  shop_id      String
  supplier_id  String
  number       String
  invoice_date DateTime
  due_date     DateTime?
  status       InvoiceStatus
  subtotal     Int
  tax_total    Int
  total        Int
  paid_total   Int                   @default(0)
  notes        String?
  created_at   DateTime              @default(now())
  updated_at   DateTime              @updatedAt
  deleted      Boolean               @default(false)
  deleted_at   DateTime?
  version      Int                   @default(1)
  items        SupplierInvoiceItem[]
  shop         Shop                  @relation(fields: [shop_id], references: [id])
  supplier     Supplier              @relation(fields: [supplier_id], references: [id])

  @@unique([shop_id, number])
  @@index([shop_id, supplier_id])
  @@map("supplier_invoices")
}

model SupplierInvoiceItem {
  id          String          @id @default(uuid())
  invoice_id  String
  product_id  String
  description String?
  qty         Float
  unit_cost   Int
  tax_rate    Float
  subtotal    Int
  tax_total   Int
  total       Int
  created_at  DateTime        @default(now())
  updated_at  DateTime        @updatedAt
  deleted     Boolean         @default(false)
  deleted_at  DateTime?
  version     Int             @default(1)
  invoice     SupplierInvoice @relation(fields: [invoice_id], references: [id])
  product     Product         @relation(fields: [product_id], references: [id])

  @@map("supplier_invoice_items")
}

model Sale {
  id             String        @id @default(uuid())
  shop_id        String
  customer_id    String?
  cashier_id     String
  status         SaleStatus
  payment_method PaymentMethod
  subtotal       Int
  discount       Int           @default(0)
  tax_total      Int
  net_total      Int
  grand_total    Int
  paid_total     Int           @default(0)
  change         Int           @default(0)
  notes          String?
  created_at     DateTime      @default(now())
  updated_at     DateTime      @updatedAt
  deleted        Boolean       @default(false)
  deleted_at     DateTime?
  version        Int           @default(1)
  device_id      String?
  client_op_id   String?
  invoices       Invoice[]
  items          SaleItem[]
  cashier        User          @relation(fields: [cashier_id], references: [id])
  customer       Customer?     @relation(fields: [customer_id], references: [id])
  shop           Shop          @relation(fields: [shop_id], references: [id])

  @@index([shop_id, created_at])
  @@index([shop_id, customer_id])
  @@map("sales")
}

model SaleItem {
  id           String    @id @default(uuid())
  sale_id      String
  product_id   String
  product_name String
  sku          String
  qty          Float
  unit_price   Int
  discount     Int       @default(0)
  tax_rate     Float
  subtotal     Int
  tax_total    Int
  total        Int
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt
  deleted      Boolean   @default(false)
  deleted_at   DateTime?
  version      Int       @default(1)
  product      Product   @relation(fields: [product_id], references: [id])
  sale         Sale      @relation(fields: [sale_id], references: [id])

  @@map("sale_items")
}

model Invoice {
  id          String        @id @default(uuid())
  shop_id     String
  sale_id     String?
  customer_id String?
  number      String
  status      InvoiceStatus
  issue_date  DateTime
  due_date    DateTime?
  subtotal    Int
  discount    Int           @default(0)
  tax_total   Int
  grand_total Int
  paid_total  Int           @default(0)
  balance_due Int
  notes       String?
  pdf_url     String?
  pdf_data    String?
  created_at  DateTime      @default(now())
  updated_at  DateTime      @updatedAt
  deleted     Boolean       @default(false)
  deleted_at  DateTime?
  version     Int           @default(1)
  items       InvoiceItem[]
  customer    Customer?     @relation(fields: [customer_id], references: [id])
  sale        Sale?         @relation(fields: [sale_id], references: [id])
  shop        Shop          @relation(fields: [shop_id], references: [id])

  @@unique([shop_id, number])
  @@index([shop_id, customer_id])
  @@map("invoices")
}

model InvoiceItem {
  id          String    @id @default(uuid())
  invoice_id  String
  product_id  String?
  description String
  qty         Float
  unit_price  Int
  discount    Int       @default(0)
  tax_rate    Float
  subtotal    Int
  tax_total   Int
  total       Int
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt
  deleted     Boolean   @default(false)
  deleted_at  DateTime?
  version     Int       @default(1)
  invoice     Invoice   @relation(fields: [invoice_id], references: [id])
  product     Product?  @relation(fields: [product_id], references: [id])

  @@map("invoice_items")
}

model Payment {
  id           String        @id @default(uuid())
  shop_id      String
  ref_type     RefType
  ref_id       String
  method       PaymentMethod
  amount       Int
  receipt_ref  String?
  notes        String?
  cashier_id   String?
  device_id    String
  client_op_id String        @unique
  created_at   DateTime      @default(now())
  updated_at   DateTime      @updatedAt
  deleted      Boolean       @default(false)
  deleted_at   DateTime?
  version      Int           @default(1)
  shop         Shop          @relation(fields: [shop_id], references: [id])

  @@index([shop_id, ref_type, ref_id])
  @@index([device_id, client_op_id])
  @@map("payments")
}

model CashEntry {
  id           String        @id @default(uuid())
  shop_id      String
  type         CashEntryType
  amount       Int
  note         String?
  cashier_id   String
  device_id    String?
  client_op_id String?       @unique
  created_at   DateTime      @default(now())
  updated_at   DateTime      @updatedAt
  deleted      Boolean       @default(false)
  deleted_at   DateTime?
  version      Int           @default(1)
  category     String?       @db.VarChar(100)
  supplier_id  String?
  customer_id  String?
  cashier      User          @relation(fields: [cashier_id], references: [id])
  customer     Customer?     @relation(fields: [customer_id], references: [id])
  shop         Shop          @relation(fields: [shop_id], references: [id])
  supplier     Supplier?     @relation(fields: [supplier_id], references: [id])

  @@index([shop_id, created_at])
  @@index([shop_id, type, created_at])
  @@index([supplier_id])
  @@index([customer_id])
  @@map("cash_entries")
}

model CashSession {
  id               String            @id @default(uuid())
  shop_id          String
  cashier_id       String
  status           CashSessionStatus
  opening_balance  Int
  closing_balance  Int?
  expected_balance Int?
  difference       Int?
  opened_at        DateTime
  closed_at        DateTime?
  notes            String?
  created_at       DateTime          @default(now())
  updated_at       DateTime          @updatedAt
  deleted          Boolean           @default(false)
  deleted_at       DateTime?
  version          Int               @default(1)
  cashier          User              @relation(fields: [cashier_id], references: [id])
  shop             Shop              @relation(fields: [shop_id], references: [id])

  @@index([shop_id, cashier_id])
  @@map("cash_sessions")
}

model PinInvite {
  id           String    @id @default(uuid())
  pin_code     String    @unique @db.VarChar(4)
  shop_id      String
  role         Role
  display_name String    @db.VarChar(255)
  created_by   String
  valid_from   DateTime  @default(now())
  valid_until  DateTime
  is_active    Boolean   @default(true)
  used_by      String?
  used_at      DateTime?
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt
  deleted      Boolean   @default(false)
  deleted_at   DateTime?

  @@index([pin_code, is_active])
  @@index([shop_id, role])
  @@map("pin_invites")
}

model DeviceSyncState {
  id              String    @id @default(uuid())
  device_id       String    @unique
  shop_id         String
  last_sync_at    DateTime?
  cursor          String?
  entity_versions Json?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt
  shop            Shop      @relation(fields: [shop_id], references: [id])

  @@index([shop_id, device_id])
  @@map("device_sync_states")
}

enum Role {
  OWNER
  MANAGER
  CASHIER
  SUPERADMIN
  ADMIN
  EMPLOYEE
}

enum MovementType {
  SALE
  PURCHASE
  ADJUSTMENT
  INVENTORY
}

enum SessionStatus {
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum ReceivableStatus {
  PENDING
  PARTIAL
  PAID
  CANCELLED
}

enum DebtStatus {
  PENDING
  PARTIAL
  PAID
  CANCELLED
}

enum SaleStatus {
  DRAFT
  COMPLETED
  CANCELLED
}

enum PaymentMethod {
  CASH
  CARD
  MOBILE
  CREDIT
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  CANCELLED
}

enum RefType {
  SALE
  INVOICE
  SUPPLIER_INVOICE
  CUSTOMER_CREDIT
}

enum CashEntryType {
  IN
  OUT
  OPENING
  CLOSING
}

enum CashSessionStatus {
  OPEN
  CLOSED
}
